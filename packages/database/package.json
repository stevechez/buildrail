{
	"name": "@buildrail/database",
	"version": "0.1.0",
	"private": true,
	"description": "Shared Supabase client factories (browser, server, middleware, admin) for all BuildRail apps.",
	"license": "UNLICENSED",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./browser": {
			"types": "./src/browser.ts",
			"default": "./src/browser.ts"
		},
		"./server": {
			"types": "./src/server.ts",
			"default": "./src/server.ts"
		},
		"./middleware": {
			"types": "./src/middleware.ts",
			"default": "./src/middleware.ts"
		},
		"./admin": {
			"types": "./src/admin.ts",
			"default": "./src/admin.ts"
		}
	},
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"files": [
		"src"
	],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsc --noEmit",
		"lint": "echo \"no lint configured for @buildrail/database\""
	},
	"peerDependencies": {
		"next": ">=14"
	},
	"dependencies": {
		"@supabase/ssr": "^0.12",
		"@supabase/supabase-js": "^2",
		"server-only": "^0.0.1"
	},
	"devDependencies": {
		"@types/node": "^20",
		"typescript": "^5"
	}
}
