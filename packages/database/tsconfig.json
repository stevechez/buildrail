{
	"extends": "../../tsconfig.settings.json",
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["ES2020", "dom"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"declaration": false,
		"noEmit": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"jsx": "react-jsx"
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules", "dist"]
}
